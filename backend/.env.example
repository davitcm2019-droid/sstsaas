NODE_ENV=development
PORT=5000

# Obrigatorias (a API nao inicia sem elas)
MONGO_URI=
JWT_SECRET=
CORS_ORIGIN=http://localhost:3000

# Opcionais
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10
PUPPETEER_HEADLESS=true
# PUPPETEER_EXECUTABLE_PATH=
DOCUMENT_STORAGE_PROVIDER=local
DOCUMENT_STORAGE_BUCKET=
DOCUMENT_STORAGE_REGION=us-east-1
DOCUMENT_STORAGE_ENDPOINT=
DOCUMENT_STORAGE_ACCESS_KEY_ID=
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=
DOCUMENT_STORAGE_PUBLIC_BASE_URL=
DOCUMENT_STORAGE_FORCE_PATH_STYLE=true
DOCUMENT_STORAGE_SIGNED_URL_TTL_SECONDS=900

# Feature flags
FEATURE_STRUCTURED_RISK_SURVEY=true
